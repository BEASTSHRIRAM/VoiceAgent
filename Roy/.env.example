# LiveKit Configuration
# Get these from https://dashboard.livekit.io
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here
LIVEKIT_URL=wss://your-livekit-url

# OpenAI Configuration
# Get this from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# Convex Database Configuration
# Get these from https://dashboard.convex.dev
CONVEX_DEPLOYMENT=dev:your-deployment|...
CONVEX_URL=https://your-deployment.convex.cloud

# Optional: Deepgram STT (if using)
# DEEPGRAM_API_KEY=your_deepgram_key

# Optional: Cartesia TTS (if using)
# CARTESIA_API_KEY=your_cartesia_key
