# Convex Configuration
# Get these from https://dashboard.convex.dev
CONVEX_DEPLOYMENT=dev:your-deployment

# Public Convex URLs (safe to expose)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# LiveKit Configuration (Server-side - DO NOT expose with NEXT_PUBLIC_)
# Get these from https://dashboard.livekit.io
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here
LIVEKIT_URL=wss://your-livekit-url

# LiveKit Configuration (Client-side - safe to expose)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-url
